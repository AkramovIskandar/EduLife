# EduLife — Vercel Environment Variables (Import .env)
# 1) Barcha YOUR_... va paste_... qiymatlarni almashtiring
# 2) Vercel → Settings → Environment Variables → Import .env
# 3) Production + Preview + Development belgilang → Save → Redeploy

SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_ANON_KEY=paste_anon_public_key_here
SUPABASE_SERVICE_ROLE_KEY=paste_service_role_secret_key_here
EDU_SESSION_SECRET=ChangeMe_To_A_Random_String_At_Least_32_Chars
ADMIN_USERNAME=admin123
ADMIN_PASSWORD=admin
ADMIN_DISPLAY_NAME=EduLife Admin
GEMINI_API_KEY=paste_gemini_api_key_here
