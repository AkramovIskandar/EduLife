# Lokal: nusxalang → .env (gitga qo'shmang)
# Vercel: vercel.env.example → to'ldiring → Import .env
# Qo'llanma: DEPLOY-VERCEL-UZ.md

# --- Build + frontend (majburiy) ---
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_ANON_KEY=your_anon_public_key_here

# --- Server API (majburiy) ---
SUPABASE_SERVICE_ROLE_KEY=your_service_role_secret_key
EDU_SESSION_SECRET=generate_a_random_string_at_least_32_chars_long

# --- Admin login (majburiy production uchun) ---
ADMIN_USERNAME=your_admin_username_here
ADMIN_PASSWORD=your_secure_password_here
ADMIN_DISPLAY_NAME=EduLife Admin

# --- Hidden backup vault (server archive) ---
EDU_VAULT_INGEST_KEY=edulife_vault_backup_key_2026

# --- AI Speaking (OpenRouter yoki Gemini) ---
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=openrouter/free
OPENROUTER_SITE_URL=https://your-site.example
OPENROUTER_APP_NAME=EduLife
GEMINI_API_KEY=your_gemini_api_key_here
